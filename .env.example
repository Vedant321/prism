PRISM_DATABRICKS_PROFILE=DEFAULT
PRISM_DATABRICKS_TABLE=databricks_virtue_foundation_dataset_dais_2026.virtue_foundation_dataset.facilities

# Optional: enables full OpenAI Realtime speech-to-speech voice chat.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin

# Alternatively, configure explicit SQL access instead of a CLI profile:
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...
# DATABRICKS_WAREHOUSE_ID=...
